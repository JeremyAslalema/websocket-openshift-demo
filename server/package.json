{
  "name": "websocket-server",
  "version": "1.0.0",
  "description": "WebSocket Server with Socket.io for OpenShift",
  "main": "dist/index.js",
  "scripts": {
    "build": "echo 'Build skipped - using pre-compiled files'",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prebuild": "echo 'Using pre-compiled dist/'",
